# ─────────────────────────────────────────────────────────
# IP Mint — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://ipmint.io
# For local dev: http://localhost:3000

# ── Blockchain ───────────────────────────────────────────
# Polygon Mainnet RPC (Alchemy, Infura, or public)
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com

# Your deployed IPMint contract address (after running deploy:contract)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Wallet private key for server-side gas sponsorship (KEEP SECRET)
# This wallet pays gas for all paid-tier mints
DEPLOYER_PRIVATE_KEY=

# WalletConnect Cloud Project ID — get at cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── IPFS / Pinata ─────────────────────────────────────────
# Get these at app.pinata.cloud → API Keys
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
PINATA_JWT=

# ── Database ─────────────────────────────────────────────
# Supabase: Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Auth (NextAuth) ───────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://ipmint.io
# For local dev: http://localhost:3000

# Email provider (for magic link sign-in)
# Works with any SMTP. Resend example:
EMAIL_SERVER=smtp://resend:[api-key]@smtp.resend.com:465
EMAIL_FROM=noreply@ipmint.io

# ── Stripe ───────────────────────────────────────────────
# Get at dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret — from Stripe dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create products in Stripe dashboard first
# Creator plan: $9.99/month recurring
STRIPE_CREATOR_PRICE_ID=price_...
# Founder plan: $29/month recurring
STRIPE_FOUNDER_PRICE_ID=price_...
# Agency plan: $99/month recurring
STRIPE_AGENCY_PRICE_ID=price_...
